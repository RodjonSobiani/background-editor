{
  "name": "background-editor-back",
  "version": "0.5.2",
  "description": "background-editor-back",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "NODE_ENV=production ts-node src/cmd/main.ts",
    "dev": "nodemon src/cmd/main.ts",
    "start:local": "tsx watch src/cmd/main.ts",
    "start:local:bun": "bun --watch src/cmd/main.ts",
    "start:build": "bun build && node -r source-map-support/register build/cmd/main.ts",
    "kysely-codegen": "npx kysely-codegen --out-file src/internal/database/models/index.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "code-check": "tsc --noEmit",
    "migrate:make": "knex migrate:make new_migration -x ts",
    "migrate": "npx knex migrate:latest",
    "migrate:up": "knex migrate:latest",
    "migrate:down": "knex migrate:rollback"
  },
  "repository": {
    "type": "git",
    "url": "git+https://"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://"
  },
  "homepage": "https://",
