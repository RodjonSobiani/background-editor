    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/multipart": "^9.0.3",
    "@fastify/sensible": "^6.0.3",
    "archiver": "^7.0.1",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-cron": "^1.4.0",
    "fastify-plugin": "^5.0.1",
    "handlebars": "^4.7.8",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "kysely": "^0.27.5",
    "lodash": "^4.17.21",
    "minio": "^8.0.4",
    "nodemailer": "^6.10.0",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "swagger-jsdoc": "^6.2.8",
    "toad-scheduler": "^3.0.1",
    "uuid": "^11.1.0",
